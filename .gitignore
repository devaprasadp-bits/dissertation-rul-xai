# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data — raw and processed data should not be committed
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Model checkpoints
*.pt
*.pth
*.ckpt

# Classical model files (too large for GitHub)
models/classical/

# Local session and notes
.claude/
internal-notes/

# MLflow
mlruns/

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/

# Reports (generated figures and tables)
reports/figures/*
reports/tables/*
!reports/figures/.gitkeep
!reports/tables/.gitkeep
